#!/bin/bash
# get-ipv4: Extract IPv4 address from network interface
# Usage: get-ipv4 <interface>

if [ $# -ne 1 ]; then
    echo "Usage: get-ipv4 <interface>"
    exit 1
fi

INTERFACE="$1"

ip addr show "$INTERFACE" 2>/dev/null | \
    grep -oP 'inet \K[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | \
    head -n 1 | \
    tr -d '\n'