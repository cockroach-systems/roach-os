#!/bin/bash
# mk-target: Create organized target directory with direnv environment and auto-start tmux session
# Usage: mk-target <TNAME> <RHOST>
# Automatically enters the directory and starts a tmux session named TNAME

set -e

if [ $# -ne 2 ]; then
    echo "Usage: mk-target <TNAME> <RHOST>"
    echo "  TNAME: Target name (directory name)"
    echo "  RHOST: Remote host IP/hostname"
    echo ""
    echo "Example: mk-target htb-box 10.10.10.123"
    echo "Creates directory 'htb-box' with .envrc, auto-allows direnv, and starts tmux session"
    exit 1
fi

TNAME="$1"
RHOST="$2"

# Validate target name (no special chars that would break directories)
if [[ ! "$TNAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Error: TNAME must contain only alphanumeric characters, hyphens, and underscores"
    exit 1
fi

# Validate RHOST (basic IP or hostname format)
if [[ ! "$RHOST" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    echo "Error: RHOST contains invalid characters"
    exit 1
fi

echo "[+] Creating target directory: $TNAME"

# Create target directory
if [ -d "$TNAME" ]; then
    echo "Warning: Directory '$TNAME' already exists"
    read -p "Continue anyway? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 0
    fi
else
    mkdir "$TNAME"
fi

# Create .envrc file with target variables
echo "[+] Creating .envrc with target environment"
cat > "$TNAME/.envrc" << 'ENVRC_EOF'
# Target Environment Variables
# Generated by mk-target

export TNAME="$TNAME"
export RHOST="$RHOST"

# Common engagement variables (customize as needed)
export LHOST="$(ip route get $RHOST | awk '{print $7; exit}')"
export LPORT="9001"

# Derived variables
export TARGET_DIR="$PWD"
export WORDLISTS="/arsenal/wordlists"
export SHELLS_LIN="/arsenal/rshells/lin"
export SHELLS_WIN="/arsenal/rshells/win"

# Output formatting
export RED='\033[0;31m'
export GREEN='\033[0;32m'
export YELLOW='\033[0;33m'
export BLUE='\033[0;34m'
export NC='\033[0m' # No Color

# === Structured Command Logging (for AI training data) ===
export ROACH_CMD_LOG="$TARGET_DIR/logs/commands.jsonl"
_ROACH_LAST_CMD=""
_ROACH_CMD_START=""

# Capture command before execution (DEBUG trap)
_roach_preexec() {
    _ROACH_LAST_CMD="$BASH_COMMAND"
    _ROACH_CMD_START=$(date +%s.%N)
}

# Log command after execution (PROMPT_COMMAND)
_roach_postcmd() {
    local exit_code=$?
    [[ -z "$_ROACH_LAST_CMD" ]] && return
    [[ "$_ROACH_LAST_CMD" == "_roach_postcmd" ]] && return

    local end_time=$(date +%s.%N)
    local duration=$(echo "$end_time - $_ROACH_CMD_START" | bc 2>/dev/null || echo "0")

    # Log as JSONL (one JSON object per line)
    printf '{"ts":"%s","cmd":"%s","exit":%d,"dur":"%.2f","pwd":"%s","target":"%s","rhost":"%s"}\n' \
        "$(date -Iseconds)" \
        "$(echo "$_ROACH_LAST_CMD" | sed 's/"/\\"/g' | tr '\n' ' ')" \
        "$exit_code" \
        "$duration" \
        "$PWD" \
        "$TNAME" \
        "$RHOST" >> "$ROACH_CMD_LOG"

    _ROACH_LAST_CMD=""
}

# Enable structured logging
trap '_roach_preexec' DEBUG
PROMPT_COMMAND="_roach_postcmd${PROMPT_COMMAND:+; $PROMPT_COMMAND}"

echo -e "${GREEN}[+] Target Environment Loaded${NC}"
echo -e "Target: ${YELLOW}$TNAME${NC} ($RHOST)"
echo -e "LHOST: $LHOST | LPORT: $LPORT"
echo -e "${BLUE}[+] Command logging: $ROACH_CMD_LOG${NC}"
ENVRC_EOF

# Now substitute the actual values into the envrc
sed -i "s/\$TNAME/$TNAME/g; s/\$RHOST/$RHOST/g" "$TNAME/.envrc"

# Create basic directory structure
echo "[+] Creating directory structure"
cd "$TNAME"
mkdir -p {scans,exploits,loot,www,logs}

echo "[+] Target setup complete!"
echo ""
echo "Directory structure:"
echo "  $TNAME/"
echo "  ├── .envrc           # Environment variables"
echo "  ├── scans/           # Nmap, masscan output"
echo "  ├── exploits/        # Custom exploits, payloads"
echo "  ├── loot/            # Credentials, files, screenshots"
echo "  ├── logs/            # Session recordings + commands.jsonl"
echo "  └── www/             # Files to serve over HTTP"
echo ""
echo "[+] Allowing direnv and starting tmux session..."

# Allow direnv for the new directory
direnv allow

# Start tmux session with TNAME and auto-record
if command -v tmux >/dev/null 2>&1; then
    LOGFILE="$PWD/logs/session_$(date +%Y%m%d_%H%M%S).log"
    echo "[+] Starting tmux session: $TNAME"
    echo "[+] Recording to: $LOGFILE"

    # Create session detached, enable logging, then attach
    tmux new-session -d -s "$TNAME" -c "$PWD"
    tmux pipe-pane -t "$TNAME" "cat >> '$LOGFILE'"
    exec tmux attach -t "$TNAME"
else
    echo "[!] tmux not found, staying in directory"
    exec bash
fi