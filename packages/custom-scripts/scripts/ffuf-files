#!/bin/bash
# ffuf-files: File fuzzing using ffuf with target environment
# Usage: ffuf-files [extensions] [path_pattern]
# Examples:
#   ffuf-files                           # Default extensions: .html,.php,.asp,.txt
#   ffuf-files .js,.json                # Custom extensions
#   ffuf-files .php /api/FUZZ            # Custom extensions and path

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check for required environment variables
if [ -z "$TNAME" ] || [ -z "$RHOST" ]; then
    echo -e "${RED}[!] Error: TNAME and RHOST must be set${NC}"
    echo "Usage: Run this from a target directory created with mk-target"
    echo "Example:"
    echo "  mk-target htb-box 10.10.10.123"
    echo "  cd htb-box"
    echo "  direnv allow"
    echo "  ffuf-files"
    echo "  ffuf-files .php,.asp"
    echo "  ffuf-files .js /api/FUZZ"
    exit 1
fi

# Create scans directory if it doesn't exist
mkdir -p scans

# Parse arguments
EXTENSIONS=""
PATH_PATTERN="FUZZ"

if [ $# -ge 1 ]; then
    # Check if first argument looks like extensions (starts with .)
    if [[ "$1" == .* ]]; then
        EXTENSIONS="$1"
        if [ $# -ge 2 ]; then
            PATH_PATTERN="$2"
        fi
    else
        # First argument is path pattern
        PATH_PATTERN="$1"
    fi
fi

# Set default extensions if not provided
if [ -z "$EXTENSIONS" ]; then
    EXTENSIONS=".html,.php,.asp,.txt,.js"
fi

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
OUTPUT_FILE="./scans/${TNAME}_ffuf_files_${TIMESTAMP}.txt"

echo -e "${GREEN}[+] Starting file fuzzing on $RHOST${NC}"
echo -e "${YELLOW}[*] Target: $TNAME${NC}"
echo -e "${YELLOW}[*] Extensions: $EXTENSIONS${NC}"
echo -e "${YELLOW}[*] Path pattern: /$PATH_PATTERN${NC}"
echo -e "${YELLOW}[*] Output: $OUTPUT_FILE${NC}"
echo ""

# Detect if HTTPS should be used (basic heuristic)
if [[ "$RHOST" == *":443" ]] || [[ "$RHOST" == "https://"* ]]; then
    PROTOCOL="https"
else
    PROTOCOL="http"
fi

# Remove protocol prefix if already present
CLEAN_RHOST=$(echo "$RHOST" | sed 's|^https\?://||')

echo -e "${BLUE}[*] Using protocol: $PROTOCOL${NC}"
echo ""

# Run ffuf file scan
ffuf -u "${PROTOCOL}://${CLEAN_RHOST}/${PATH_PATTERN}" \
     -c \
     -w /arsenal/wordlists/Discovery/Web-Content/raft-medium-files-lowercase.txt \
     -mc 200,301,302 \
     -e "$EXTENSIONS" \
     -o "$OUTPUT_FILE" \
     -of txt

echo ""
echo -e "${GREEN}[+] File fuzzing completed!${NC}"
echo -e "${YELLOW}[*] Output saved to: $OUTPUT_FILE${NC}"
echo ""

# Show quick summary if output file has content
if [ -f "$OUTPUT_FILE" ] && [ -s "$OUTPUT_FILE" ]; then
    echo -e "${GREEN}[+] Found files:${NC}"
    grep -E "Status: (200|301|302)" "$OUTPUT_FILE" | head -10 || echo "Check output file for results"
    
    TOTAL_FOUND=$(grep -c "Status: " "$OUTPUT_FILE" 2>/dev/null || echo "0")
    echo ""
    echo -e "${BLUE}[*] Total files found: $TOTAL_FOUND${NC}"
    
    # Show breakdown by extension if multiple found
    if [ "$TOTAL_FOUND" -gt 1 ]; then
        echo -e "${BLUE}[*] Breakdown by extension:${NC}"
        grep "Status: " "$OUTPUT_FILE" | grep -o '\.[a-zA-Z0-9]*' | sort | uniq -c | head -5 || true
    fi
else
    echo -e "${YELLOW}[*] No files found or scan still processing${NC}"
fi