#!/bin/bash
# nmap-quick: Quick nmap scan using target environment
# Usage: nmap-quick (uses $TNAME and $RHOST from environment)

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

# Check for required environment variables
if [ -z "$TNAME" ] || [ -z "$RHOST" ]; then
    echo -e "${RED}[!] Error: TNAME and RHOST must be set${NC}"
    echo "Usage: Run this from a target directory created with mk-target"
    echo "Example:"
    echo "  mk-target htb-box 10.10.10.123"
    echo "  cd htb-box"
    echo "  direnv allow"
    echo "  nmap-quick"
    exit 1
fi

# Create scans directory if it doesn't exist
mkdir -p scans

# Set output files
OUTPUT_BASE="./scans/${TNAME}_quick"
NMAP_FILE="${OUTPUT_BASE}.nmap"
XML_FILE="${OUTPUT_BASE}.xml"

echo -e "${GREEN}[+] Starting quick scan of $RHOST${NC}"
echo -e "${YELLOW}[*] Target: $TNAME${NC}"
echo -e "${YELLOW}[*] Output: $NMAP_FILE${NC}"
echo ""

# Determine scan type based on privileges
if [ "$EUID" -eq 0 ]; then
    SCAN_TYPE="-sS"
    echo -e "${GREEN}[+] Running as root - using SYN scan${NC}"
else
    SCAN_TYPE="-sT"
    echo -e "${YELLOW}[*] Running as user - using connect scan${NC}"
fi

# Run nmap quick scan
nmap $SCAN_TYPE \
     --top-ports 1000 \
     -sV \
     -sC \
     -O \
     --version-intensity 5 \
     --osscan-guess \
     -oN "$NMAP_FILE" \
     -oX "$XML_FILE" \
     "$RHOST"

echo ""
echo -e "${GREEN}[+] Quick scan completed!${NC}"
echo -e "${YELLOW}[*] Normal output: $NMAP_FILE${NC}"
echo -e "${YELLOW}[*] XML output: $XML_FILE${NC}"
echo ""
echo -e "${GREEN}[+] Open ports summary:${NC}"
grep -E "^[0-9]+/(tcp|udp)" "$NMAP_FILE" | head -20 || echo "No open ports found"