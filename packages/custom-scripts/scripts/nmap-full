#!/bin/bash
# nmap-full: Full port nmap scan using target environment
# Usage: nmap-full (uses $TNAME and $RHOST from environment)

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check for required environment variables
if [ -z "$TNAME" ] || [ -z "$RHOST" ]; then
    echo -e "${RED}[!] Error: TNAME and RHOST must be set${NC}"
    echo "Usage: Run this from a target directory created with mk-target"
    echo "Example:"
    echo "  mk-target htb-box 10.10.10.123"
    echo "  cd htb-box"
    echo "  direnv allow"
    echo "  nmap-full"
    exit 1
fi

# Create scans directory if it doesn't exist
mkdir -p scans

# Set output files
OUTPUT_BASE="./scans/${TNAME}_full"
NMAP_FILE="${OUTPUT_BASE}.nmap"
XML_FILE="${OUTPUT_BASE}.xml"

echo -e "${GREEN}[+] Starting full port scan of $RHOST${NC}"
echo -e "${YELLOW}[*] Target: $TNAME${NC}"
echo -e "${YELLOW}[*] Output: $NMAP_FILE${NC}"
echo -e "${BLUE}[*] This may take a while - scanning all 65535 ports${NC}"
echo ""

# Determine scan type based on privileges
if [ "$EUID" -eq 0 ]; then
    SCAN_TYPE="-sS"
    echo -e "${GREEN}[+] Running as root - using SYN scan${NC}"
else
    SCAN_TYPE="-sT"
    echo -e "${YELLOW}[*] Running as user - using connect scan${NC}"
fi

# Run nmap full port scan
nmap $SCAN_TYPE \
    -p- \
    -sV \
    -sC \
    --min-rate=1000 \
    -T4 \
    --max-retries=1 \
    --open \
    -oN "$NMAP_FILE" \
    -oX "$XML_FILE" \
    "$RHOST"

echo ""
echo -e "${GREEN}[+] Full port scan completed!${NC}"
echo -e "${YELLOW}[*] Normal output: $NMAP_FILE${NC}"
echo -e "${YELLOW}[*] XML output: $XML_FILE${NC}"
echo ""

# Show open ports summary
if grep -q "^[0-9]" "$NMAP_FILE" 2>/dev/null; then
    echo -e "${GREEN}[+] Open ports found:${NC}"
    grep -E "^[0-9]+/(tcp|udp)" "$NMAP_FILE" || echo "No detailed port info available"
    echo ""
    echo -e "${BLUE}[*] Run nmap-quick for service detection on these ports${NC}"
else
    echo -e "${YELLOW}[*] No open ports found or scan still in progress${NC}"
fi

